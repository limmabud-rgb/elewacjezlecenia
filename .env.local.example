# Skopiuj ten plik do .env.local i wklej dane ze swojego projektu Supabase
# (Supabase → Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj-anon-public-key

# Klucz kryptograficzny do podpisywania sesji logowania. To NIE jest
# hasło do aplikacji (to ustawiasz i zmieniasz w samej apce, na ekranie
# "Zmień hasło dostępu") — to jest tylko techniczny sekret serwera.
# Wpisz dowolny długi, losowy ciąg znaków (np. 32+ znaków) i nigdy go
# nie udostępniaj. Wygenerować taki ciąg możesz np. komendą:
#   openssl rand -hex 32
SESSION_SECRET=ustaw-dlugi-losowy-ciag-znakow
