# Skopiuj ten plik do .env.local i wklej dane ze swojego projektu Supabase
# (Supabase → Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj-anon-public-key

# Hasło chroniące dostęp do całej aplikacji (ekran logowania).
# Wybierz własne, dowolne hasło — nie musi być skomplikowane,
# ważne żeby nie znali go osoby z zewnątrz firmy.
APP_PASSWORD=ustaw-wlasne-haslo
